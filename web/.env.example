# --- LLM Provider 配置 ---
# 切换 LLM 后端："openai-compat"（默认，开发环境）| "dashscope"（生产环境）
LLM_PROVIDER=openai-compat

# DashScope API Key（阿里云百炼平台：https://bailian.console.aliyun.com/）
# 当 LLM_PROVIDER=dashscope 时使用
DASHSCOPE_API_KEY=sk-your-api-key-here
# DashScope 并发控制（图像生成等耗时 API）
# DASHSCOPE_CONCURRENCY=2       # 最大并发请求数（默认 2）
# DASHSCOPE_RETRY_DELAY=3000    # 失败重试等待时间，毫秒（默认 3000）
# TRYON_MODEL=qwen-image-2.0    # 试穿模型（默认），同步接口，¥0.2/张
# TRYON_MODEL=qwen-image-2.0-pro  # 高质量版，同步接口，¥0.5/张
# TRYON_MODEL=wan2.5-i2i-preview   # 万相图编辑，异步接口(~45s)，¥0.2/张

# OpenAI 兼容 API（当 LLM_PROVIDER=openai-compat 时使用）
OPENAI_COMPAT_BASE_URL=http://openai.infly.tech/v1/
OPENAI_COMPAT_API_KEY=your-api-key-here
OPENAI_COMPAT_MODEL=gpt-4o
OPENAI_COMPAT_VISION_MODEL=gpt-4o

# 和风天气（https://dev.qweather.com）
# 用于获取实时天气、天气预报、穿衣指数等数据
QWEATHER_API_KEY=your-qweather-api-key-here
# API Host — 在控制台「项目管理」中查看，格式如 xxx.re.qweatherapi.com
QWEATHER_API_HOST=your-host.re.qweatherapi.com

# JWT 认证
JWT_SECRET=your-random-secret-at-least-32-chars

# 淘宝商品导入（订单侠 API：https://www.dingdanxia.com）
# 用于解析淘口令和获取商品详情
TAOBAO_API_KEY=your-dingdanxia-api-key
