generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Item {
  id                String   @id @default(cuid())
  name              String
  category          String
  subcategory       String?
  color             String?
  style             String?
  season            String?
  occasion          String?
  brand             String?
  price             Float?
  purchaseDate      String?
  notes             String?
  imagePath         String
  originalImagePath String?  /// 原始上传图片路径（未抠图），用于去重比对
  imageHash         String?  /// 原始图片 SHA-256 哈希，用于检测重复上传
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PersonImage {
  id        String   @id @default(cuid())
  name      String
  imagePath String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Outfit {
  id              String    @id @default(cuid())
  personImageId   String
  topItemId       String?
  bottomItemId    String?
  resultImagePath String
  isFavorite      Boolean   @default(false)
  score           Float?
  scoreDims       String?
  evaluation      String?
  scoredAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([personImageId, topItemId, bottomItemId])
}

model DailyRecommendation {
  id        String   @id @default(cuid())
  date      String
  rank      Int
  outfitId  String
  reason    String?
  createdAt DateTime @default(now())

  @@unique([date, rank])
}

/// 天气数据缓存（按小时+城市，30天自动过期）
model WeatherCache {
  id         String   @id @default(cuid())
  locationId String
  hourKey    String   /// 格式 YYYYMMDDHH，如 "2026031714"
  data       String   /// 完整 WeatherData JSON
  createdAt  DateTime @default(now())
  expiresAt  DateTime /// createdAt + 30 天，查询时过滤

  @@unique([locationId, hourKey])
  @@index([expiresAt])
}
