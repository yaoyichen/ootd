generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Item {
  id           String   @id @default(cuid())
  name         String
  category     String
  subcategory  String?
  color        String?
  style        String?
  season       String?
  occasion     String?
  brand        String?
  price        Float?
  purchaseDate String?
  notes        String?
  imagePath    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PersonImage {
  id        String   @id @default(cuid())
  name      String
  imagePath String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Outfit {
  id              String    @id @default(cuid())
  personImageId   String
  topItemId       String?
  bottomItemId    String?
  resultImagePath String
  isFavorite      Boolean   @default(false)
  score           Float?
  scoreDims       String?
  evaluation      String?
  scoredAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([personImageId, topItemId, bottomItemId])
}

model DailyRecommendation {
  id        String   @id @default(cuid())
  date      String
  rank      Int
  outfitId  String
  reason    String?
  createdAt DateTime @default(now())

  @@unique([date, rank])
}
