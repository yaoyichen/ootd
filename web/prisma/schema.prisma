generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Item {
  id                String   @id @default(cuid())
  name              String
  category          String
  subcategory       String?
  color             String?
  style             String?
  season            String?
  occasion          String?
  material          String?  /// 材质（棉、牛仔、丝绸、羊毛、涤纶、皮革等）
  fit               String?  /// 版型（修身、宽松、常规、oversize）
  pattern           String?  /// 图案（纯色、条纹、格纹、印花、碎花）
  thickness         String?  /// 厚度（薄、适中、厚）
  description       String?  /// 简短描述（如"V领开衫，金属纽扣"）
  imagePath         String
  originalImagePath String?  /// 原始上传图片路径（未抠图），用于去重比对
  imageHash         String?  /// 原始图片 SHA-256 哈希，用于检测重复上传
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PersonImage {
  id                String   @id @default(cuid())
  name              String
  imagePath         String
  enhancedImagePath String?  /// 美化后的图片路径
  description       String?  /// AI 分析的结构化描述 JSON
  isDefault         Boolean  @default(false)
  createdAt         DateTime @default(now())
}

model Outfit {
  id              String          @id @default(cuid())
  personImageId   String
  topItemId       String?
  bottomItemId    String?
  resultImagePath String
  isFavorite      Boolean         @default(false)
  score           Float?
  scoreDims       String?
  evaluation      String?
  scoredAt        DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  showcasePosts   ShowcasePost[]

  @@unique([personImageId, topItemId, bottomItemId])
}

model ShowcasePost {
  id         String   @id @default(cuid())
  outfitId   String
  outfit     Outfit   @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  caption    String?
  likes      Int      @default(0)
  tryonCount Int      @default(0)
  isPublic   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isPublic, createdAt])
  @@index([isPublic, likes])
}

model DailyRecommendation {
  id        String   @id @default(cuid())
  date      String
  rank      Int
  outfitId  String
  reason    String?
  createdAt DateTime @default(now())

  @@unique([date, rank])
}

/// 天气数据缓存（按小时+城市，30天自动过期）
model WeatherCache {
  id         String   @id @default(cuid())
  locationId String
  hourKey    String   /// 格式 YYYYMMDDHH，如 "2026031714"
  data       String   /// 完整 WeatherData JSON
  createdAt  DateTime @default(now())
  expiresAt  DateTime /// createdAt + 30 天，查询时过滤

  @@unique([locationId, hourKey])
  @@index([expiresAt])
}
